# JWT secret for authentication (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# Google OAuth Client ID (from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=

# Neon PostgreSQL connection string
# Get this from https://neon.tech after creating a project
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Vercel Blob read/write token
# Automatically set when you add Blob storage via Vercel dashboard
BLOB_READ_WRITE_TOKEN=

# SMTP settings for email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
